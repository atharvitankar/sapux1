{
  "_version": "1.60.0",

  "sap.app": {

    "id": "demo.comp.composite",

    "type": "application",

    "i18n": "i18n/i18n.properties",

    "title": "Machine Monitor Composite",

    "description": "Factory Machine Monitoring Dashboard",

    "applicationVersion": {
      "version": "1.0.0"
    }

  },

  "sap.ui": {

    "technology": "UI5",

    "icons": {

    },

    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }

  },

  "sap.ui5": {

    "flexEnabled": false,

    "rootView": {

      "viewName": "demo.comp.composite.view.Main",

      "type": "XML",

      "async": true,

      "id": "Main"

    },

    "dependencies": {

      "minUI5Version": "1.120.0",

      "libs": {

        "sap.m": {},

        "sap.ui.core": {}

      }

    },

    "contentDensities": {

      "compact": true,

      "cozy": true

    },

    "models": {

    },

    "resources": {

      "css": [
        {
          "uri": "css/style.css"
        }
      ]

    }

  }

}